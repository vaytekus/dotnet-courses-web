@model CoursesApp.Web.DTOs.Auth.LoginDto

@section Scripts {
    <script src="~/js/auth.js" asp-append-version="true"></script>
}  

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center mt-5">
    
    <div class="col-md-4">
        <h2 class="mb-4">Login</h2>

        <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="email@example.com"/>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="Password" type="password" class="form-control" id="login-password" />
                    <button class="btn btn-outline-secondary" type="button" id="toggle-login-password">👁</button>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input"/>
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Sign in</button>
        </form>

        <p class="mt-3 text-center">
            Don't have an account? <a asp-action="Register">Register</a>
        </p>
    </div>
</div>