@model CoursesApp.Web.Models.TeachersIndexViewModel

@{
    Layout = null;
}

@if (!Model.Teachers.Any())
{
    <tr><td colspan="4" class="text-center">No teachers found.</td></tr>
}
else
{
    @for (int i = 0; i < Model.Teachers.Count; i++)
    {
        <tr data-id="@Model.Teachers[i].Id"
            data-first-name="@Model.Teachers[i].FirstName"
            data-last-name="@Model.Teachers[i].LastName">
            <td>@((Model.Page - 1) * Model.PageSize + i + 1)</td>
            <td>
                <span class="view-mode">
                    @Model.Teachers[i].FirstName
                </span>
                <span class="edit-mode d-none">
                    <input class="form-control" value="@Model.Teachers[i].FirstName" name="firstName"/>
                </span>
            </td>
            <td>
                <span class="view-mode">
                    @Model.Teachers[i].LastName
                </span>
                <span class="edit-mode d-none">
                    <input class="form-control" value="@Model.Teachers[i].LastName" name="lastName"/>
                </span>
            </td>
            <td>
                <span class="view-mode">
                    <button class="btn btn-sm btn-primary btn-edit">Edit</button>
                    <button class="btn btn-sm btn-danger btn-delete">Delete</button>
                </span>
                <span class="edit-mode d-none">
                    <button class="btn btn-sm btn-success btn-save">Save</button>
                    <button class="btn btn-sm btn-secondary btn-cancel">Cancel</button>
                </span>
            </td>
        </tr>
    }
    
    @if (Model.TotalPages > 1)
    {
        <tr>
            <td colspan="4" class="text-center">
                <button class="btn btn-sm btn-outline-secondary btn-page" data-page="@(Model.Page - 1)" disabled="@(Model.Page == 1)">«</button>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || (i >= Model.Page - 2 && i <= Model.Page + 2))
                    {
                        <button class="btn btn-sm @(i == Model.Page ? "btn-primary" : "btn-outline-secondary") btn-page"
                                data-page="@i">@i</button>
                    }
                    else if (i == Model.Page - 3 || i == Model.Page + 3)
                    {
                        <span class="px-1">...</span>
                    }
                }

                <button class="btn btn-sm btn-outline-secondary btn-page" data-page="@(Model.Page + 1)" disabled="@(Model.Page == Model.TotalPages)">»</button>
            </td>
        </tr>
    }
}