@model CoursesApp.Web.Models.TeachersIndexViewModel

@section Scripts
{
    <script>
        window.initialSort = {
            key: '@(Model.SortKey == TeacherSortKey.FirstName ? "firstName" : "lastName")',
            desc: @Model.SortDesc.ToString().ToLower()
        };
    </script>
    <script src="~/js/teachers.js"></script>
}

@{
    ViewData["Title"] = "Teachers";
}
<h1>@ViewData["Title"]</h1>

<form action="#" id="add-teacher-form" class="mb-3">
    <div class="input-group d-none align-items-center gap-2">
        <div class="col">
            <label for="teacherFirstName" class="form-label">First Name</label>
            <input type="text" class="form-control" placeholder="First name" id="teacherFirstName">
        </div>
        <div class="col">
            <label for="teacherLastName" class="form-label">Last Name</label>
            <input type="text" class="form-control" placeholder="Last name" id="teacherLastName">
        </div>
        <div class="col">
            <label class="form-label">&nbsp;</label>
            <div>
                <button id="btn-add-save" type="button" class="btn btn-sm btn-success" disabled>Save</button>
                <button id="btn-add-cancel" type="button" class="btn btn-sm btn-secondary">Cancel</button>
            </div>
        </div>
    </div>
    <div class="button-holder">
        <button id="btn-add-teacher" type="button" class="btn btn-sm btn-primary">+ Add Teacher</button>
    </div>
</form>

<hr class="my-2 pt-2">

<form id="search-teacher-form" class="d-flex align-items-center gap-2 mb-3 position-relative">
    <span class="text-muted small fw-semibold me-1">Filters:</span>
    <div class="position-relative w-25">
        <input type="text" id="search-input" class="form-control" placeholder="Search by name..." autocomplete="off">
        <div id="search-suggestions" class="list-group position-absolute w-100 shadow-sm d-none"
             style="z-index: 1050; top: 100%; max-height: 240px; overflow-y: auto;"></div>
    </div>
</form>

<table class="table align-middle" id="teachers-table" style="table-layout: fixed">
    <colgroup>
        <col style="width: 50px">
        <col>
        <col>
        <col style="width: 160px">
    </colgroup>
    <thead>
    <tr>
        <th>#</th>
        <th class="sortable" data-sort-key="firstName" style="cursor: pointer; user-select: none">
            First Name <span class="sort-arrow"></span>
        </th>
        <th class="sortable" data-sort-key="lastName" style="cursor: pointer; user-select: none">
            Last Name <span class="sort-arrow"></span>
        </th>
        <th>Action</th>
    </tr>
    </thead>
    <tbody>
        @await Html.PartialAsync("_TeachersTableBody", Model)
    </tbody>
</table>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete teacher <strong id="delete-target-name"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btn-confirm-delete">Delete</button>
            </div>
        </div>
    </div>
</div>