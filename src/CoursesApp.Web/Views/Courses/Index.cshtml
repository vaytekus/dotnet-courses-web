@model List<CoursesApp.Domain.Entities.Course>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Courses</h1>
    @if (!Model.Any())
    {
        <p>No courses found.</p>
    }
    else
    {
        <ul class="accordion list-group" id="accordionCourse">
            @foreach (var course in Model)
            {
                <li class="accordion-item list-group-item">
                    <div class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@course.Id" aria-expanded="false" aria-controls="collapse-@course.Id">
                            <div class="d-flex flex-wrap align-items-center gap-2 pe-3 w-100">
                                <h2 class="mb-0 me-2">@course.Name</h2>
                                @if (course.Level.HasValue)
                                {
                                    <span class="badge bg-info text-dark">@course.Level</span>
                                }
                                @if (course.DurationWeeks.HasValue)
                                {
                                    <span class="badge bg-secondary">@course.DurationWeeks wk</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(course.Category))
                                {
                                    <span class="badge bg-light text-dark border">@course.Category</span>
                                }
                                <span class="text-muted ms-2">@course.Description</span>
                            </div>
                        </button>
                    </div>
                    <div id="collapse-@course.Id" class="accordion-collapse collapse" data-bs-parent="#accordionCourse">
                        <div class="accordion-body">
                            <ul class="accordion list-group" id="accordionGroup-@course.Id">
                                @foreach (var group in course.Groups)
                                {
                                    <li class="accordion-item list-group-item">
                                        <div class="accordion-header">
                                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@group.Id" aria-expanded="true" aria-controls="collapse-@group.Id">
                                                <h3>@group.Name</h3>
                                            </button>
                                        </div>
                                        <div id="collapse-@group.Id"
                                            class="accordion-collapse collapse"
                                            data-bs-parent="#accordionGroup-@course.Id"
                                            data-group-id="@group.Id"
                                            data-readonly="true">
                                            <div class="students-container"></div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>