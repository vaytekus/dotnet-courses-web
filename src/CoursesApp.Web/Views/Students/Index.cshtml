@model CoursesApp.Web.Models.StudentsIndexViewModel

@section Scripts
{
    <script src="~/js/students.js"></script>
}

@{
    ViewData["Title"] = "Students";
}
<h1>@ViewData["Title"]</h1>

<form action="#" id="add-student-form" class="mb-3">
    <div class="row input-group d-none align-items-center">
        <div class="col">
            <label for="studentFirstName" class="form-label">First Name</label>
            <input type="text" class="form-control" placeholder="First name" aria-label="First name" id="studentFirstName">
        </div>
        <div class="col">
            <label for="studentLastName" class="form-label">Last Name</label>
            <input type="text" class="form-control" placeholder="Last name" aria-label="Last name" id="studentLastName">
        </div>
        <div class="col">
            <label for="selectStudentGroup" class="form-label">Groups</label>
            <select class="form-select" name="groupId" id="selectStudentGroup">
                <option value="">Choose group</option>
                @foreach (var group in Model.Groups)
                {
                    <option value="@group.Id">@group.Name</option>
                }
            </select>
        </div>
        <div class="col">
            <label class="form-label">&nbsp;</label>
            <div>
                <button id="btn-add-save" type="button" class="btn btn-sm btn-success" disabled>Save</button>
                <button id="btn-add-cancel" type="button" class="btn btn-sm btn-secondary">Cancel</button>
            </div>
        </div>
    </div>
    <div class="button-holder">
        <button id="btn-add-student" type="button" class="btn btn-sm btn-primary">+ Add Student</button>
    </div>
</form>

<hr class="my-2 pt-2">

<form action="#" id="search-student-form" class="d-flex align-items-center gap-2 mb-3">
    <span class="text-muted small fw-semibold me-1">Filters:</span>
    <input id="search-input" type="text" class="form-control w-25" placeholder="Search by name...">
    <select class="form-select w-25" name="searchGroupId" id="filteringByGroup">
        <option value="">All groups</option>
        @foreach (var group in Model.Groups)
        {
            <option value="@group.Id">@group.Name</option>
        }
    </select>
</form>

<table class="table align-middle" id="students-table" style="table-layout: fixed">
    <colgroup>
        <col style="width: 50px">
        <col>
        <col>
        <col>
        <col style="width: 160px">
    </colgroup>
    <thead>
    <tr>
        <th>#</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Group</th>
        <th>Action</th>
    </tr>
    </thead>
    <tbody>
        @await Html.PartialAsync("_StudentsTableBody", Model)
    </tbody>
</table>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this student?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btn-confirm-delete">Delete</button>
            </div>
        </div>
    </div>
</div>
