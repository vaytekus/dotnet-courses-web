@model List<CoursesApp.Domain.Entities.Group>

@{
    ViewData["Title"] = "Groups";
}
<h1>@ViewData["Title"]</h1>

@if (!Model.Any())
{
    <p>No groups found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Course</th>
                <th>Teacher</th>
                <th>Students qty</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@(i+1)</td>
                    <td>@Model[i].Name</td>
                    <td>@Model[i].Course.Name</td>
                    <td>@Model[i].Teacher?.FirstName @Model[i].Teacher?.LastName</td>
                    <td>@Model[i].Students.Count</td>
                </tr>
            }
        </tbody>
    </table>
}