@model List<CoursesApp.Web.DTOs.StudentDto>

@{
    Layout = null;
}

<div class="d-flex justify-content-end gap-2 mb-2 pt-3">
    <button class="btn btn-sm btn-outline-success btn-export-students" type="button">↓ Export</button>
    <button class="btn btn-sm btn-outline-primary btn-import-students" type="button">↑ Import</button>
    @if (Model.Any())
    {
        <button class="btn btn-sm btn-warning btn-clear-students" type="button">Clear all students</button>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted mb-0">No students in this group.</p>
}
else
{
    <table class="table table-sm mb-0" style="table-layout: fixed">
        <colgroup>
            <col style="width: 50px">
            <col>
            <col>
            <col>
        </colgroup>
        <thead>
            <tr>
                <th>#</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @{ int j = 1; }
            @foreach (var student in Model)
            {
                <tr data-id="@student.Id">
                    <td>@(j++)</td>
                    <td>@student.FirstName</td>
                    <td>@student.LastName</td>
                    <td>
                        <button class="btn btn-sm btn-danger btn-delete">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}